  {% render 'partials/head6.liquid' %}
 <div class="app">
 
    <!-- Sticky top: header + filters + zoek -->
    <div class="sticky-top">
     <header class="header">
  <a class="back" href="/">← Terug</a>
  <h1>Veld nieuws</h1>
</header>
 
      <!-- Filters -->
      <nav aria-label="Nieuwscategorieën" class="filters">
        <button class="filter-btn active" aria-pressed="true">Laatste</button>
        <button class="filter-btn" aria-pressed="false">In de bloei</button>
        <button class="filter-btn" aria-pressed="false">Na de bloei</button>
      </nav>
 
      <!-- Search -->
      <div class="search-wrap" role="search">
        <div class="search-inner">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          <input type="search" placeholder="Search" aria-label="Zoek in nieuws" />
        </div>
      </div>
    </div>
 
    <!-- Scrollbaar gedeelte -->
    <div class="scroll-area">
      <main>
        <section class="news-list" aria-label="Nieuwsartikelen">
        {% for news in news %}
        <a class="news-item" href="/nieuws_detail/{{ news.slug }}">
          <!-- Vervang src met jouw afbeelding -->
          <img src="https://fdnd-agency.directus.app/assets/{{ news.image }}" width="100" height="120" alt="nieuws">
          <div class="news-content">
            <span class="news-tag">{{ news.date }}</span>
            <p class="news-title">{{ news.title }}</p>
          </div>
        </a>
    {% endfor %}
        
 
        </section>
      </main>
    </div><!-- /.scroll-area -->
 
  </div><!-- /.app -->

  {% render 'partials/nav.liquid' %}
{% render 'partials/foot.liquid' %}
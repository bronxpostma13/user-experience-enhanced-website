{% render 'partials/head7.liquid' %}
<section class="page-wrapper">

    <!-- Header -->
    
     <div class="sticky-top">
     <header class="header">
  <a class="back" href="/nieuws">← Terug</a>
  <h1>Veld nieuws</h1>
</header>
</div>
    <!-- Article -->
    <main class="article">

      <section class="article-image-wrap">
        <img src="https://fdnd-agency.directus.app/assets/{{ news.image }}" width="300" height="400" alt="nieuws">
      </section>

      <section class="article-body">
        <span class="article-date">Geplaatst: {{ news.date }}</span>
        <h2 class="article-title">{{ news.title }}</h2>
        <p class="article-text">  {{ news.body }} </p>
      </section>

    </main>
     
     <section class="reacties-section">
         <article class="reactie-form-placeholder">
      <h2 class="reacties-titel" >Voeg jou reactie toe</h2>
      <form action="/nieuws_detail/{{ news.slug }}" method="POST">
        <label >
            Naam:
            <input type="text" name="name"  required>
        </label>
<br>
        <label>
        Reactie:
        <textarea name="comment" maxlength="95" class="placeholder-textarea" required></textarea>
        </label>

        <input type="hidden" name="id" value="{{ news.id }}">
        <label>
            <button type="submit" value="Versturen" class="placeholder-btn"></button>
      </label>
      </form>
    </article>

    <h2 class="reacties-title">Reacties</h2>

    <!-- Bestaande reacties -->
    <ul class="reacties-list">
    
   {% for reactie in reactie %}
      <li class="reactie-card">
          <div class="reactie-meta">
            <span class="reactie-naam">{{ reactie.name }}</span>
            <span class="reactie-datum">18 november 2025</span>
       
        <p class="reactie-tekst">{{ reactie.comment }}</p>
      </li>
       {% endfor %}
     
      </ul>
  </section>
  </section>
    {% render 'partials/nav.liquid' %}
{% render 'partials/foot.liquid' %}